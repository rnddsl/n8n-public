              "fieldLabel": "Brand Voice",
              "fieldType": "textarea",
              "requiredField": true
            },
            {
              "fieldLabel": "Tone",
              "fieldType": "radio",
              "fieldOptions": {
                "values": [
                  {
                    "option": "Casual"
                  },
                  {
                    "option": "Professional"
                  },
                  {
                    "option": "Informative"
                  },
                  {
                    "option": "Custom"
                  }
                ]
              },
              "requiredField": true
            },
            {
              "fieldLabel": "Custom Brand Tone"
            },
            {
              "fieldType": "html",
              "html": "<!-- Your custom HTML here --->\n<div style=\"background-color: lightblue\">\n  Your data should be in .csv, xls, or xlsx format and must contain the following columns:\n<br/>\n<ul>\n  <li>product_name</li>\n  <li>product_specs</li>\n  <li>product category</li>\n</ul>\n<br/>\n</div>\n"
            },
            {
              "fieldLabel": "Bulk Upload",
              "fieldType": "file"
            }
          ]
        },
        "responseMode": "lastNode",
        "options": {
          "respondWithOptions": {
            "values": {
              "formSubmittedText": "={{ `[download](https://webhook.example.com/fake }}"
            }
